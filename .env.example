# Copiar a .env y rellenar valores reales. Nunca commitear .env.

# Base de datos
POSTGRES_DB=lapsight_db
POSTGRES_USER=lapsight_user
POSTGRES_PASSWORD=changeme

# Backend
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/lapsight_db
SPRING_DATASOURCE_USERNAME=lapsight_user
SPRING_DATASOURCE_PASSWORD=changeme

# JWT — generar con: openssl rand -base64 48
JWT_SECRET=replace-with-base64-of-at-least-32-bytes
JWT_EXPIRATION_MS=86400000

# CORS
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Seed inicial — solo activar en deploys de portfolio público.
# Si true, crea el admin demo y un equipo F1 ficticio con sesiones realistas.
APP_SEED_DEMO_DATA=false
APP_SEED_ADMIN_EMAIL=
APP_SEED_ADMIN_PASSWORD=
APP_SEED_TEAM_NAME=Demo Racing Team

# Frontend
REACT_APP_API_URL=http://localhost:8080/api
