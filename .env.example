# Copiar a .env y rellenar valores reales. Nunca commitear .env.

# Base de datos
POSTGRES_DB=racing_team_db
POSTGRES_USER=racing_user
POSTGRES_PASSWORD=changeme

# Backend
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/racing_team_db
SPRING_DATASOURCE_USERNAME=racing_user
SPRING_DATASOURCE_PASSWORD=changeme

# JWT — generar con: openssl rand -base64 48
JWT_SECRET=replace-with-base64-of-at-least-32-bytes
JWT_EXPIRATION_MS=86400000

# CORS
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Seed inicial (sólo se aplica si la tabla users está vacía para ese email)
APP_SEED_ADMIN_EMAIL=admin@racing.com
APP_SEED_ADMIN_PASSWORD=changeme
APP_SEED_TEAM_NAME=Demo Racing Team

# Frontend
REACT_APP_API_URL=http://localhost:8080/api
