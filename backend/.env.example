# LapSight backend — variables de entorno
# Copia este archivo a .env (o configúralo en tu plataforma de deploy)

# --------- Spring profile ---------
# dev | docker | prod
SPRING_PROFILES_ACTIVE=prod

# --------- Database (Postgres) ---------
# Spring usa el formato jdbc:postgresql://host:port/db
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/lapsight_db
SPRING_DATASOURCE_USERNAME=lapsight_user
SPRING_DATASOURCE_PASSWORD=changeme

# --------- JWT ---------
# Base64 de al menos 32 bytes para HS256. Generar con:
#   openssl rand -base64 48
JWT_SECRET=Y2hhbmdlLW1lLWluLXByb2R1Y3Rpb24tdXNlLWEtbG9uZy1iYXNlNjQta2V5LXBsZWFzZQ==
JWT_EXPIRATION_MS=86400000

# --------- CORS ---------
# Dominios desde los que se permite acceso. En producción debe ser el dominio público del front.
APP_CORS_ALLOWED_ORIGINS=https://lapsight.example.com

# --------- Demo seed ---------
# Si true, al arrancar crea el admin demo y datos de pilotos/vehículos/sesiones ficticios.
# Para deploys de portfolio público: true. Para producción real: false.
APP_SEED_DEMO_DATA=false
APP_SEED_ADMIN_EMAIL=admin@lapsight.app
APP_SEED_ADMIN_PASSWORD=changeme
APP_SEED_TEAM_NAME=Demo Racing Team

# --------- Python analytics microservice ---------
PYTHON_ANALYTICS_URL=http://python-analytics:8000
PYTHON_ANALYTICS_TIMEOUT_MS=15000

# --------- Rate limiting ---------
# Aplica a /auth/login y /auth/register
APP_RATE_LIMIT_AUTH_MAX=10
APP_RATE_LIMIT_AUTH_WINDOW_SEC=60

# --------- Logging ---------
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_SECURITY=WARN

# --------- Server (PaaS providers like Railway suelen inyectar PORT) ---------
PORT=8080
HIKARI_MAX_POOL=10
