# LapSight frontend — variables de entorno
# Copia a .env.local para desarrollo; para deploy configura en la plataforma (Vercel/Netlify/etc).

# --------- Dev (npm run dev) ---------
# El proxy de Vite apunta al backend. Por defecto http://localhost:8082 (host port mapeado por docker-compose).
# Cambia a http://localhost:8080 si arrancas el backend con `mvn spring-boot:run`.
VITE_API_PROXY_TARGET=http://localhost:8082

# --------- Build de producción ---------
# Base URL que el frontend usará para llamar al backend cuando está construido.
# Si no se define, el cliente usa "/api" (asumiendo que el frontend y el backend están detrás
# del mismo dominio — ej. Nginx sirve el bundle y proxy-passes /api al backend).
#
# Para deploys con frontend separado del backend:
#   VITE_API_URL=https://api.lapsight.example.com/api
# VITE_API_URL=
