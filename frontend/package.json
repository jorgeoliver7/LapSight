{
  "name": "racing-team-management-frontend",
  "version": "1.0.0",
  "description": "Frontend para gestión de equipos de motorsport",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
